Cell[CellGroupData[{

Cell["Graviton polarison sum", "Subsection",
 CellChangeTimes->{{3.9701971962758493`*^9, 3.970197196878868*^9}, {
  3.970197243635345*^9, 3.970197293921377*^9}, {3.9701976567882977`*^9, 
  3.970197710536632*^9}, {3.97019780296628*^9, 3.970197847224387*^9}, {
  3.9701979614117937`*^9, 3.970197988201926*^9}, {3.9701980365711813`*^9, 
  3.9701981893663673`*^9}, {3.9702868152668657`*^9, 3.970286819676056*^9}, {
  3.970286851227899*^9, 3.970286854796088*^9}, {3.970286917309449*^9, 
  3.97028692752612*^9}, {3.970299450306975*^9, 3.970299451954977*^9}, {
  3.970301517708515*^9, 
  3.970301524140736*^9}},ExpressionUUID->"8dc11766-3432-400c-86ef-\
24f8bc592d5f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Eta]Hat", "[", 
     RowBox[{"\[Mu]_", ",", "\[Nu]_", ",", "\[Omega]_", ",", "\[Omega]b_"}], 
     "]"}], ":=", 
    RowBox[{
     RowBox[{"MT", "[", 
      RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "-", 
     FractionBox[
      RowBox[{
       RowBox[{
        RowBox[{"FV", "[", 
         RowBox[{"\[Omega]", ",", "\[Mu]"}], "]"}], 
        RowBox[{"FV", "[", 
         RowBox[{"\[Omega]b", ",", "\[Nu]"}], "]"}]}], "+", 
       RowBox[{
        RowBox[{"FV", "[", 
         RowBox[{"\[Omega]", ",", "\[Nu]"}], "]"}], 
        RowBox[{"FV", "[", 
         RowBox[{"\[Omega]b", ",", "\[Mu]"}], "]"}]}]}], 
      RowBox[{"SP", "[", 
       RowBox[{"\[Omega]", ",", "\[Omega]b"}], "]"}]]}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"graviton", " ", "polarison", " ", "sum"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SumPol", "[", 
     RowBox[{
     "\[Mu]_", ",", "\[Nu]_", ",", "\[Alpha]_", ",", "\[Beta]_", ",", 
      "\[Omega]_", ",", "\[Omega]b_"}], "]"}], ":=", 
