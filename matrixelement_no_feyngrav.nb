         "k1", ",", "k2", ",", "k3", ",", "\[Alpha]", ",", "\[Beta]", ",", 
          "\[Mu]", ",", "\[Nu]", ",", "\[Gamma]", ",", "\[Sigma]"}], "]"}]}], 
       ")"}]}]}], ";"}], "\[IndentingNewLine]", "\t", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
