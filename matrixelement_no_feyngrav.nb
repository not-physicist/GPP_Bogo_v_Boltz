        RowBox[{"\[Sigma]", ",", "\[Mu]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Gamma]", ",", "\[Alpha]"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"SP", "[", 
        RowBox[{"k3", ",", "k2"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Sigma]", ",", "\[Gamma]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Nu]", ",", "\[Mu]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Beta]", ",", "\[Alpha]"}], "]"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"P6FV", "[", 
      RowBox[{
      "k1_", ",", "k2_", ",", "k3_", ",", "\[Mu]_", ",", "\[Nu]_", ",", 
       "\[Alpha]_", ",", "\[Beta]_", ",", "\[Sigma]_", ",", "\[Gamma]_"}], 
      "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"FV", "[", 
        RowBox[{"k1", ",", "\[Sigma]"}], "]"}], "*", 
       RowBox[{"FV", "[", 
        RowBox[{"k2", ",", "\[Mu]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Alpha]", ",", "\[Nu]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Beta]", ",", "\[Gamma]"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"FV", "[", 
        RowBox[{"k2", ",", "\[Sigma]"}], "]"}], "*", 
       RowBox[{"FV", "[", 
        RowBox[{"k1", ",", "\[Nu]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Beta]", ",", "\[Mu]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Alpha]", ",", "\[Gamma]"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"FV", "[", 
        RowBox[{"k1", ",", "\[Nu]"}], "]"}], "*", 
       RowBox[{"FV", "[", 
        RowBox[{"k3", ",", "\[Mu]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Alpha]", ",", "\[Sigma]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Gamma]", ",", "\[Beta]"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"FV", "[", 
        RowBox[{"k3", ",", "\[Nu]"}], "]"}], "*", 
       RowBox[{"FV", "[", 
        RowBox[{"k1", ",", "\[Sigma]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Gamma]", ",", "\[Mu]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Alpha]", ",", "\[Beta]"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"FV", "[", 
        RowBox[{"k3", ",", "\[Mu]"}], "]"}], "*", 
       RowBox[{"FV", "[", 
        RowBox[{"k2", ",", "\[Sigma]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Gamma]", ",", "\[Nu]"}], "]"}], "*", 
