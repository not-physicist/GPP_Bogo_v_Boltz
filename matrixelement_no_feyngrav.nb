       "\[Alpha]_", ",", "\[Beta]_", ",", "\[Sigma]_", ",", "\[Gamma]_"}], 
      "]"}], ":=", 
     RowBox[{
      RowBox[{
       FractionBox["1", "2"], 
       RowBox[{"P6SP", "[", 
        RowBox[{
        "k1", ",", "k2", ",", "k3", ",", "\[Mu]", ",", "\[Nu]", ",", 
         "\[Alpha]", ",", "\[Beta]", ",", "\[Sigma]", ",", "\[Gamma]"}], 
        "]"}]}], "-", 
      RowBox[{"P3FV", "[", 
       RowBox[{
       "k1", ",", "k2", ",", "k3", ",", "\[Mu]", ",", "\[Nu]", ",", 
        "\[Alpha]", ",", "\[Beta]", ",", "\[Sigma]", ",", "\[Gamma]"}], "]"}],
       "-", 
      RowBox[{"2", 
       RowBox[{"P3SP", "[", 
        RowBox[{
        "k1", ",", "k2", ",", "k3", ",", "\[Alpha]", ",", "\[Nu]", ",", 
         "\[Beta]", ",", "\[Sigma]", ",", "\[Gamma]", ",", "\[Mu]"}], "]"}]}],
       "+", 
      RowBox[{
       FractionBox["1", "2"], 
       RowBox[{"P3SP", "[", 
        RowBox[{
        "k1", ",", "k2", ",", "k3", ",", "\[Mu]", ",", "\[Nu]", ",", 
         "\[Alpha]", ",", "\[Beta]", ",", "\[Sigma]", ",", "\[Gamma]"}], 
        "]"}]}], "+", 
      RowBox[{"P6FV", "[", 
       RowBox[{
       "k1", ",", "k2", ",", "k3", ",", "\[Mu]", ",", "\[Nu]", ",", 
        "\[Alpha]", ",", "\[Beta]", ",", "\[Sigma]", ",", "\[Gamma]"}], "]"}],
       "-", 
      RowBox[{
       FractionBox["1", "4"], 
       RowBox[{"P3SP", "[", 
        RowBox[{
        "k1", ",", "k2", ",", "k3", ",", "\[Mu]", ",", "\[Alpha]", ",", 
         "\[Nu]", ",", "\[Beta]", ",", "\[Sigma]", ",", "\[Gamma]"}], 
        "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Momenta", " ", "all", " ", "pointing", " ", "inwards"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"MineVertexHHH", "[", 
      RowBox[{
      "k1_", ",", " ", "\[Mu]_", ",", " ", "\[Alpha]_", ",", " ", "k2_", ",", 
       " ", "\[Nu]_", ",", " ", "\[Beta]_", ",", " ", "k3_", ",", " ", 
       "\[Sigma]_", ",", " ", "\[Gamma]_"}], "]"}], ":=", 
     RowBox[{
      FractionBox["I", "Mp"], "*", 
      RowBox[{"(", 
