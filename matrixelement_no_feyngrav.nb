Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"first", " ", "define", " ", "auxilary", " ", "quantities"}], ";",
     " ", 
    RowBox[{
    "define", " ", "two", " ", "kinds", " ", "of", " ", "P3", " ", 
     "separately"}], ";", " ", 
    RowBox[{
    "first", " ", "term", " ", "should", " ", "be", " ", "the", " ", 
     "argument", " ", "of", " ", "P_", "3"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"P3SP", "[", 
      RowBox[{
      "k1_", ",", "k2_", ",", "k3_", ",", "\[Mu]_", ",", "\[Nu]_", ",", 
       "\[Alpha]_", ",", "\[Beta]_", ",", "\[Sigma]_", ",", "\[Gamma]_"}], 
      "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"SP", "[", 
        RowBox[{"k1", ",", "k2"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Alpha]", ",", "\[Beta]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Sigma]", ",", "\[Gamma]"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"SP", "[", 
        RowBox[{"k1", ",", "k3"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Mu]", ",", "\[Sigma]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Alpha]", ",", "\[Gamma]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Nu]", ",", "\[Beta]"}], "]"}]}], "+", " ", 
      RowBox[{
       RowBox[{"SP", "[", 
        RowBox[{"k2", ",", "k3"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Nu]", ",", "\[Sigma]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Beta]", ",", "\[Gamma]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Mu]", ",", "\[Alpha]"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"P3FV", "[", 
      RowBox[{
      "k1_", ",", "k2_", ",", "k3_", ",", "\[Mu]_", ",", "\[Nu]_", ",", 
       "\[Alpha]_", ",", "\[Beta]_", ",", "\[Sigma]_", ",", "\[Gamma]_"}], 
      "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"FV", "[", 
        RowBox[{"k1", ",", "\[Sigma]"}], "]"}], "*", 
       RowBox[{"FV", "[", 
        RowBox[{"k2", ",", "\[Gamma]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Alpha]", ",", "\[Beta]"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"FV", "[", 
        RowBox[{"k1", ",", "\[Nu]"}], "]"}], "*", 
       RowBox[{"FV", "[", 
        RowBox[{"k3", ",", "\[Beta]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Mu]", ",", "\[Sigma]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Alpha]", ",", "\[Gamma]"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"FV", "[", 
        RowBox[{"k3", ",", "\[Mu]"}], "]"}], "*", 
       RowBox[{"FV", "[", 
        RowBox[{"k2", ",", "\[Alpha]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Sigma]", ",", "\[Nu]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Gamma]", ",", "\[Beta]"}], "]"}]}]}]}], ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Note", " ", "that", " ", "the", " ", "two", " ", "terms", " ", "are", " ",
       "indeed", " ", "different"}], ",", " ", "respectively", ",", " ", 
     RowBox[{"even", " ", "after", " ", "symmetrization"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"P6SP", "[", 
      RowBox[{
      "k1_", ",", "k2_", ",", "k3_", ",", "\[Mu]_", ",", "\[Nu]_", ",", 
       "\[Alpha]_", ",", "\[Beta]_", ",", "\[Sigma]_", ",", "\[Gamma]_"}], 
      "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"SP", "[", 
        RowBox[{"k1", ",", "k2"}], "]"}], "*", 
       RowBox[{"MT", "[", 
