       RowBox[{"MT", "[", 
        RowBox[{"\[Nu]", ",", "\[Sigma]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Beta]", ",", "\[Gamma]"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"SP", "[", 
        RowBox[{"k2", ",", "k1"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Nu]", ",", "\[Beta]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Mu]", ",", "\[Sigma]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Alpha]", ",", "\[Gamma]"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"SP", "[", 
        RowBox[{"k1", ",", "k3"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Mu]", ",", "\[Alpha]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Sigma]", ",", "\[Nu]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Gamma]", ",", "\[Beta]"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"SP", "[", 
        RowBox[{"k3", ",", "k1"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Sigma]", ",", "\[Gamma]"}], "]"}], "*", 
       RowBox[{"MT", "[", 
        RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "*", 
