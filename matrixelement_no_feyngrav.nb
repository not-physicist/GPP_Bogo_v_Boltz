Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Second", " ", "diagram"}], ";", " ", 
    RowBox[{
    "use", " ", "transver", " ", "traceless", " ", "condition", " ", "for", " ",
      "the", " ", "matrix", " ", "element", " ", "already"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"M2", "[", 
      RowBox[{
      "\[Alpha]_", ",", "\[Beta]_", ",", "\[Gamma]_", ",", "\[Delta]_"}], 
      "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
             "\[Rho]", ",", "\[Kappa]\[Kappa]", ",", "\[Mu]", ",", "\[Nu]"}], 
             "}"}], ",", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"VertexHCond", "[", 
               RowBox[{"\[Rho]", ",", "\[Kappa]\[Kappa]"}], "]"}], "*", 
              RowBox[{"DGrav", "[", 
               RowBox[{
               "\[Rho]", ",", "\[Kappa]\[Kappa]", ",", "\[Mu]", ",", "\[Nu]", 
                ",", "s"}], "]"}], "*", 
              RowBox[{"MineVertexHHH", "[", 
               RowBox[{
                RowBox[{"p3", "+", "p4"}], ",", "\[Mu]", ",", "\[Nu]", ",", 
                RowBox[{"-", "p3"}], ",", "\[Alpha]", ",", "\[Beta]", ",", 
                RowBox[{"-", "p4"}], ",", "\[Gamma]", ",", "\[Delta]"}], 
               "]"}]}], ")"}]}], "]"}], "//", "Contract"}], "//", "FCE"}], "//",
         "FullSimplify"}], ")"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"FVD", "[", 
          RowBox[{"p3", ",", "_"}], "]"}], "->", "0"}], ",", 
        RowBox[{
         RowBox[{"FVD", "[", 
          RowBox[{"p4", ",", "_"}], "]"}], "->", "0"}], ",", 
        RowBox[{
         RowBox[{"MTD", "[", 
          RowBox[{"\[Alpha]", ",", "\[Beta]"}], "]"}], "->", "0"}], ",", 
        RowBox[{
         RowBox[{"MTD", "[", 
          RowBox[{"\[Gamma]", ",", "\[Delta]"}], "]"}], "->", "0"}]}], 
       "}"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"M2C", ":=", 
     RowBox[{
      RowBox[{"ComplexConjugate", "@", 
       RowBox[{"M2", "[", 
        RowBox[{
        "\[Alpha]C", ",", "\[Beta]C", ",", "\[Gamma]C", ",", "\[Delta]C"}], 
        "]"}]}], "//", "FCE"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"M2ms", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"M2", "[", 
        RowBox[{
        "\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]", ",", "\[Delta]"}], "]"}],
        "*", "M2C", "*", 
       RowBox[{"SumPol", "[", 
        RowBox[{
        "\[Alpha]", ",", "\[Beta]", ",", "\[Alpha]C", ",", "\[Beta]C", ",", 
         "p3", ",", "p4"}], "]"}], "*", 
       RowBox[{"SumPol", "[", 
        RowBox[{
        "\[Gamma]", ",", "\[Delta]", ",", "\[Gamma]C", ",", "\[Delta]C", ",", 
         "p4", ",", "p3"}], "]"}]}], "//", "Calc"}]}], ";"}], "\n", 
   RowBox[{"M2ms", "=", 
    RowBox[{
     RowBox[{"M2ms", "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"s", "->", 
         RowBox[{"4", 
          RowBox[{"mt", "^", "2"}]}]}], ",", 
        RowBox[{
         RowBox[{"TemporalPair", "[", 
          RowBox[{
           RowBox[{"ExplicitLorentzIndex", "[", "0", "]"}], ",", 
           RowBox[{"TemporalMomentum", "[", "p3", "]"}]}], "]"}], "->", 
         "mt"}], ",", "  ", 
        RowBox[{
         RowBox[{"TemporalPair", "[", 
          RowBox[{
           RowBox[{"ExplicitLorentzIndex", "[", "0", "]"}], ",", 
           RowBox[{"TemporalMomentum", "[", "p4", "]"}]}], "]"}], "->", 
         "mt"}]}], "}"}]}], "//", "FullSimplify"}]}]}]}]], "Input",
